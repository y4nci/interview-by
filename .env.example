# Web app port (Next.js). API uses API_PORT.
PORT=3000
# API server port (only used by the API app).
API_PORT=3001

# Full connection string for PostgreSQL database including credentials,
# host, port, database name, and connection parameters.
DATABASE_URL=

# Supabase project URL (local: http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key — used to verify JWTs client-side.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Supabase secret key — used to verify JWTs server-side.
# Get this from `supabase start` output or the Supabase dashboard.
SUPABASE_SECRET_KEY=

# The URL of the API server.
NEXT_PUBLIC_API_URL=